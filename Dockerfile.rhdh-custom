# =============================================================================
# RHDH Three Horizons — Custom Image with Embedded Dynamic Plugins
#
# Extends the official RHDH 1.8 image with 5 custom plugins baked in.
# This eliminates the need for OCI artifact loading at runtime.
#
# Build:
#   docker build -f Dockerfile.rhdh-custom -t acrbackstagedemo.azurecr.io/rhdh-three-horizons:latest .
#
# Push:
#   docker push acrbackstagedemo.azurecr.io/rhdh-three-horizons:latest
# =============================================================================

FROM quay.io/rhdh/rhdh-hub-rhel9:1.8

# ── Copy custom frontend plugins ─────────────────────────────────────────────
COPY plugins/home-three-horizons/dist-dynamic/ \
     /opt/app-root/src/dynamic-plugins/dist/internal-plugin-home-three-horizons/

COPY plugins/my-group-dashboard/dist-dynamic/ \
     /opt/app-root/src/dynamic-plugins/dist/internal-plugin-my-group-dashboard/

COPY plugins/copilot-metrics/dist-dynamic/ \
     /opt/app-root/src/dynamic-plugins/dist/internal-plugin-copilot-metrics/

COPY plugins/ghas-metrics/dist-dynamic/ \
     /opt/app-root/src/dynamic-plugins/dist/internal-plugin-ghas-metrics/

# ── Copy custom backend plugin ───────────────────────────────────────────────
COPY plugins/ghas-metrics-backend/dist-dynamic/ \
     /opt/app-root/src/dynamic-plugins/dist/internal-plugin-ghas-metrics-backend/
